@model Glitch.ViewModels.Admin.AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* Stat cards row */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 22px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: transform 0.2s, border-color 0.2s;
    }

    .stat-card:hover { transform: translateY(-3px); border-color: var(--primary); }

    .stat-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

    .stat-info h3 { font-size: 28px; font-weight: 800; }
    .stat-info p  { font-size: 13px; color: var(--muted); margin-top: 2px; }

    /* Tables */
    .tables-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .table-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }

    .table-header {
        padding: 18px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .table-header h3 { font-size: 15px; font-weight: 700; }

    .table-header a {
        font-size: 12px;
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
    }

    table { width: 100%; border-collapse: collapse; }

    th {
        padding: 10px 16px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        border-bottom: 1px solid var(--border);
        background: rgba(42,42,74,0.3);
    }

    td {
        padding: 12px 16px;
        font-size: 13px;
        border-bottom: 1px solid rgba(42,42,74,0.4);
    }

    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(99,102,241,0.05); }

    .role-badge {
        padding: 3px 10px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 700;
    }

    .role-admin    { background: rgba(99,102,241,0.2); color: #a5b4fc; }
    .role-customer { background: rgba(16,185,129,0.2); color: #6ee7b7; }
    .role-blocked  { background: rgba(239,68,68,0.2);  color: #fca5a5; }
</style>

<!-- Stat cards -->
<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(99,102,241,0.2);">🎮</div>
        <div class="stat-info">
            <h3>@Model.TotalGames</h3>
            <p>Total Games</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(16,185,129,0.2);">👥</div>
        <div class="stat-info">
            <h3>@Model.TotalUsers</h3>
            <p>Total Customers</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(245,158,11,0.2);">💰</div>
        <div class="stat-info">
            <h3>@Model.TotalPurchases</h3>
            <p>Total Purchases</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(239,68,68,0.2);">🚫</div>
        <div class="stat-info">
            <h3>@Model.BlockedUsers</h3>
            <p>Blocked Users</p>
        </div>
    </div>

</div>

<!-- Recent tables -->
<div class="tables-grid">

    <!-- Recent Users -->
    <div class="table-card">
        <div class="table-header">
            <h3>👥 Recent Users</h3>
            <a href="/Admin/Users">View All →</a>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Joined</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.RecentUsers)
                {
                    <tr>
                        <td>
                            <div style="font-weight:700;">@user.Username</div>
                            <div style="font-size:11px; color:var(--muted);">@user.Email</div>
                        </td>
                        <td>
                            @if (user.IsBlocked)
                            {
                                <span class="role-badge role-blocked">Blocked</span>
                            }
                            else if (user.Role == "Admin")
                            {
                                <span class="role-badge role-admin">Admin</span>
                            }
                            else
                            {
                                <span class="role-badge role-customer">Customer</span>
                            }
                        </td>
                        <td style="color:var(--muted);">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                    </tr>
                }
                @if (!Model.RecentUsers.Any())
                {
                    <tr><td colspan="3" style="text-align:center; color:var(--muted); padding:24px;">No users yet</td></tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Recent Purchases -->
    <div class="table-card">
        <div class="table-header">
            <h3>💰 Recent Purchases</h3>
        </div>
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Game</th>
                    <th>Price</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.RecentPurchases)
                {
                    <tr>
                        <td style="font-weight:700;">@p.Username</td>
                        <td style="color:var(--muted);">@p.GameTitle</td>
                        <td style="color:var(--primary); font-weight:700;">$@p.PricePaid.ToString("F2")</td>
                    </tr>
                }
                @if (!Model.RecentPurchases.Any())
                {
                    <tr><td colspan="3" style="text-align:center; color:var(--muted); padding:24px;">No purchases yet</td></tr>
                }
            </tbody>
        </table>
    </div>

</div>