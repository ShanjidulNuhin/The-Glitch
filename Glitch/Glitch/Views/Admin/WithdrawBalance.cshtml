@model Glitch.ViewModels.Admin.WithdrawViewModel
@inject Glitch.Data.AppDbContext DbContext

@{
    ViewData["Title"] = "Withdraw Balance";
    Layout = null;
    var username = Context.Session.GetString("Username") ?? "";
    var userIdStr = Context.Session.GetString("UserId");
    var hasDob = Model.DateOfBirth.HasValue;
    var dobStr = hasDob ? Model.DateOfBirth?.ToString("yyyy-MM-dd") : "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Withdraw Balance — Glitch</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --bg: #0f0f1a;
            --card: #1a1a2e;
            --border: #2a2a4a;
            --text: #fff;
            --muted: #888;
            --success: #10b981;
            --error: #f87171;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navbar */
        .navbar {
            position: fixed; top: 0; left: 0; width: 100%;
            z-index: 1000;
            display: flex; align-items: center;
            justify-content: space-between;
            padding: 14px 40px;
            background: rgba(15,15,26,0.92);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
        }

        .navbar-logo {
            font-size: 20px; font-weight: 800;
            color: var(--primary); text-decoration: none;
        }

        .navbar-logo span { color: #fff; }

        .navbar-actions { display: flex; gap: 10px; align-items: center; }

        .btn-outline {
            padding: 8px 18px;
            border: 1px solid var(--primary); color: var(--primary);
            background: transparent; border-radius: 8px;
            font-size: 13px; font-weight: 600;
            text-decoration: none; transition: all 0.2s;
        }

        .btn-outline:hover { background: var(--primary); color: #fff; }

        /* Page content */
        .page-wrap {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 100px 30px 60px;
        }

        .balance-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            position: relative;
            overflow: hidden;
        }

        .balance-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 6px;
            background: linear-gradient(90deg, #10b981, #3b82f6);
        }

        .balance-title {
            text-align: center;
            font-size: 28px; font-weight: 900;
            margin-bottom: 8px;
        }

        .balance-subtitle {
            text-align: center;
            font-size: 14px; color: var(--muted);
            margin-bottom: 32px;
        }

        /* Tabs */
        .method-tabs {
            display: flex; gap: 10px; margin-bottom: 24px;
            background: rgba(0,0,0,0.2); padding: 6px; border-radius: 12px;
        }

        .method-tab {
            flex: 1; text-align: center; padding: 12px;
            background: transparent; border: none; border-radius: 8px;
            color: var(--muted); font-size: 14px; font-weight: 700;
            cursor: pointer; transition: all 0.2s;
        }

        .method-tab.active {
            background: var(--primary); color: #fff;
            box-shadow: 0 4px 12px rgba(99,102,241,0.3);
        }

        /* Form groups */
        .form-section { display: none; animation: fadeIn 0.3s ease; }
        .form-section.active { display: block; }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .form-group { margin-bottom: 20px; }
        .form-group label {
            display: block; font-size: 12px; font-weight: 700;
            color: var(--muted); text-transform: uppercase;
            letter-spacing: 1px; margin-bottom: 8px;
        }

        .form-group input, .form-group select {
            width: 100%; padding: 12px 16px;
            background: rgba(15,15,26,0.6);
            border: 1px solid var(--border);
            border-radius: 10px; color: #fff;
            font-size: 16px; outline: none; transition: all 0.2s;
        }

        .form-group input:focus, .form-group select:focus {
            border-color: var(--primary); box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
        }

        .form-group input[readonly] {
            background: rgba(255,255,255,0.05); color: var(--muted); cursor: not-allowed;
        }

        .mobile-apps {
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
        }

        .mobile-app {
            background: rgba(255,255,255,0.05); border: 1px solid var(--border);
            border-radius: 12px; padding: 16px 10px; text-align: center;
            cursor: pointer; transition: all 0.2s;
            font-weight: 700; font-size: 14px;
        }

        .mobile-app:hover, .mobile-app.active {
            border-color: var(--primary); background: rgba(99,102,241,0.1);
        }

        .btn-submit {
            width: 100%; padding: 16px;
            background: var(--success); color: #000;
            border: none; border-radius: 10px;
            font-size: 16px; font-weight: 800;
            cursor: pointer; transition: all 0.2s;
            box-shadow: 0 4px 14px rgba(16,185,129,0.3);
            margin-top: 10px;
        }

        .btn-submit:hover {
            background: #059669; color: #fff; transform: translateY(-2px);
        }

        /* Modals */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); backdrop-filter: blur(5px);
            z-index: 2000; display: none; align-items: center; justify-content: center;
        }

        .modal-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 16px; padding: 30px; width: 100%; max-width: 400px;
            text-align: center; animation: modalIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @@keyframes modalIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }

        .modal-title { font-size: 20px; font-weight: 800; margin-bottom: 20px; }
        
        .modal-input {
            width: 100%; padding: 12px 16px; margin-bottom: 20px;
            background: rgba(15,15,26,0.6); border: 1px solid var(--border);
            border-radius: 10px; color: #fff; font-size: 18px; text-align: center;
            letter-spacing: 2px; outline: none;
        }

        .modal-input:focus { border-color: var(--primary); }
        
        .modal-btn {
            width: 100%; padding: 14px; background: var(--primary); color: #fff;
            border: none; border-radius: 10px; font-size: 16px; font-weight: 700;
            cursor: pointer;
        }

        .modal-btn:hover { background: var(--primary-dark); }
        
        .modal-close {
            margin-top: 15px; background: transparent; border: none;
            color: var(--muted); font-size: 14px; cursor: pointer; text-decoration: underline;
        }

        /* Loading */
        .loading-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(26,26,46,0.9); z-index: 100;
            display: none; align-items: center; justify-content: center; flex-direction: column;
            border-radius: 20px;
        }

        .spinner {
            width: 50px; height: 50px;
            border: 4px solid rgba(255,255,255,0.1);
            border-top-color: var(--success);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 16px;
        }

        @@keyframes spin { 100% { transform: rotate(360deg); } }
        
        .error-msg { color: var(--error); font-size: 13px; margin-top: 4px; display: none; }
        
        .validation-summary-errors {
            color: var(--error);
            font-size: 13px;
            margin-bottom: 15px;
            text-align: center;
            background: rgba(248,113,113,0.1);
            padding: 10px;
            border-radius: 8px;
            list-style: none;
        }
        .validation-summary-errors ul { list-style: none; padding: 0; }
        
        .btn-back {
            width: 100%; padding: 16px;
            background: transparent; color: var(--muted);
            border: 1px solid var(--border); border-radius: 10px;
            font-size: 16px; font-weight: 800;
            cursor: pointer; transition: all 0.2s;
            margin-top: 10px;
            display: block;
            text-align: center;
            text-decoration: none;
        }

        .btn-back:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            border-color: var(--primary);
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <a href="/" class="navbar-logo">🎮 The<span>Glitch</span></a>
        <div class="navbar-actions">
            @{
                decimal navBalance = 0;
                if (!string.IsNullOrEmpty(userIdStr))
                {
                    var navUser = await DbContext.Users.FindAsync(int.Parse(userIdStr));
                    if (navUser != null) navBalance = navUser.Balance;
                }
            }
            <a href="/Admin/WithdrawBalance" class="btn-outline" style="border-color:#10b981; color:#10b981;">
                <span>💰</span> $@navBalance.ToString("0.00")
            </a>
            <a href="/Admin/Index" class="btn-outline">📊 Dashboard</a>
            <a href="/Admin/Profile" class="btn-outline">Profile</a>
        </div>
    </nav>

    <div class="page-wrap">
        <div class="balance-card">
            <div class="loading-overlay" id="loadingOverlay">
                <div class="spinner"></div>
                <h3>Processing Withdrawal...</h3>
            </div>

            <h2 class="balance-title">Withdraw Funds</h2>
            <p class="balance-subtitle">Choose a method to withdraw money<br/><span style="color:var(--success)">Max Withdrawable: $@Model.WithdrawableBalance.ToString("0.00")</span></p>

            <div class="method-tabs">
                <button class="method-tab active" onclick="setMethod('Bank')">Bank</button>
                <button class="method-tab" onclick="setMethod('Card')">Card</button>
                <button class="method-tab" onclick="setMethod('Mobile')">Mobile App</button>
            </div>

            <form id="addBalanceForm" asp-action="WithdrawBalance" asp-controller="Admin" method="post" onsubmit="return handleFormSubmit(event)">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="validation-summary-errors">
                        <ul>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <input type="hidden" asp-for="PaymentMethod" id="hiddenMethod" value="Bank" />
                <input type="hidden" asp-for="Amount" id="hiddenAmount" />

                <!-- BANK SECTION -->
                <div id="sectionBank" class="form-section active">
                    <div class="form-group">
                        <label>Bank Account Number</label>
                        <input type="text" id="bankAcc" placeholder="e.g. 1234567890" />
                        <div class="error-msg" id="bankAccErr">Required</div>
                    </div>
                    <div class="form-group">
                        <label>PIN</label>
                        <input type="password" id="bankPin" placeholder="****" />
                        <div class="error-msg" id="bankPinErr">Required</div>
                    </div>
                    <div class="form-group">
                        <label>Amount ($)</label>
                        <input type="number" id="bankAmount" step="0.01" min="1" placeholder="0.00" />
                        <div class="error-msg" id="bankAmountErr">Please enter a valid amount</div>
                    </div>
                    <button type="submit" class="btn-submit">Withdraw Balance</button>
                </div>

                <!-- CARD SECTION -->
                <div id="sectionCard" class="form-section">
                    <div class="form-group">
                        <label>Select Card</label>
                        <select id="cardType">
                            <option value="Visa">Visa</option>
                            <option value="Credit">Credit Card</option>
                            <option value="ATM">ATM Card</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Card Number (12 digits)</label>
                        <input type="text" id="cardNum" maxlength="12" placeholder="123456789012" />
                        <div class="error-msg" id="cardNumErr">Must be 12 digits</div>
                    </div>
                    <div class="form-group">
                        <label>Date of Birth</label>
                        @if (hasDob)
                        {
                            <input type="date" asp-for="DateOfBirth" value="@dobStr" readonly />
                        }
                        else
                        {
                            <input type="date" asp-for="DateOfBirth" id="cardDob" />
                        }
                        <div class="error-msg" id="cardDobErr">Required</div>
                    </div>
                    <div class="form-group">
                        <label>PIN</label>
                        <input type="password" id="cardPin" placeholder="****" />
                        <div class="error-msg" id="cardPinErr">Required</div>
                    </div>
                    <div class="form-group">
                        <label>Amount ($)</label>
                        <input type="number" id="cardAmount" step="0.01" min="1" placeholder="0.00" />
                        <div class="error-msg" id="cardAmountErr">Please enter a valid amount</div>
                    </div>
                    <button type="submit" class="btn-submit">Withdraw Balance</button>
                </div>

                <!-- MOBILE SECTION -->
                <div id="sectionMobile" class="form-section">
                    <div class="form-group">
                        <label>Select Mobile Provider</label>
                        <div class="mobile-apps">
                            <div class="mobile-app" onclick="startMobileFlow('Bkash')">Bkash</div>
                            <div class="mobile-app" onclick="startMobileFlow('Nagad')">Nagad</div>
                            <div class="mobile-app" onclick="startMobileFlow('Rocket')">Rocket</div>
                        </div>
                    </div>
                    <div style="text-align: center; color: var(--muted); font-size: 14px; margin-top: 20px;">
                        Click a provider to proceed
                    </div>
                </div>

            </form>
            <button type="button" onclick="window.history.back()" class="btn-back">&larr; Back</button>
        </div>
    </div>

    <!-- Modals for Mobile Flow -->
    <div class="modal-overlay" id="mobileModal1">
        <div class="modal-card">
            <div class="modal-title" id="mobileTitle1">Enter Mobile Number</div>
            <div style="color: var(--muted); margin-bottom: 10px; font-size: 14px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;">Country: Bangladesh</div>
            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
                <input type="text" value="+880" readonly style="width: 85px; padding: 12px; background: rgba(15,15,26,0.6); border: 1px solid var(--border); border-radius: 10px; color: #fff; font-size: 16px; font-weight: bold; text-align: center; outline: none; cursor: not-allowed;" />
                <input type="text" class="modal-input" id="mobileNum" maxlength="11" placeholder="Number" style="margin-bottom: 0; flex: 1;" />
            </div>
            <div class="error-msg" id="mobileNumErr" style="margin-top:-10px; margin-bottom:15px;">Invalid number</div>
            <button class="modal-btn" onclick="nextMobileModal(2)">Confirm</button>
            <button class="modal-close" onclick="closeModals()">Cancel</button>
        </div>
    </div>

    <div class="modal-overlay" id="mobileModal2">
        <div class="modal-card">
            <div class="modal-title" id="mobileTitle2">Enter PIN</div>
            <input type="password" class="modal-input" id="mobilePin" placeholder="****" />
            <div class="error-msg" id="mobilePinErr" style="margin-top:-10px; margin-bottom:15px;">Invalid PIN</div>
            <button class="modal-btn" onclick="nextMobileModal(3)">Confirm</button>
            <button class="modal-close" onclick="closeModals()">Cancel</button>
        </div>
    </div>

    <div class="modal-overlay" id="mobileModal3">
        <div class="modal-card">
            <div class="modal-title">Enter Amount ($)</div>
            <input type="number" class="modal-input" id="mobileAmount" step="0.01" min="1" placeholder="0.00" />
            <div class="error-msg" id="mobileAmountErr" style="margin-top:-10px; margin-bottom:15px;">Valid amount required</div>
            <button class="modal-btn" onclick="submitMobile()">Confirm Withdrawal</button>
            <button class="modal-close" onclick="closeModals()">Cancel</button>
        </div>
    </div>

    <script>
        let currentMethod = 'Bank';
        let currentProvider = '';

        function setMethod(method) {
            currentMethod = method;
            document.getElementById('hiddenMethod').value = method;
            
            document.querySelectorAll('.method-tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');

            document.querySelectorAll('.form-section').forEach(s => s.classList.remove('active'));
            document.getElementById('section' + method).classList.add('active');
        }

        // Mobile Flow
        function startMobileFlow(provider) {
            currentProvider = provider;
            document.getElementById('mobileNum').value = '';
            document.getElementById('mobilePin').value = '';
            document.getElementById('mobileAmount').value = '';
            hideErrors();
            
            document.getElementById('mobileTitle1').innerText = provider + " - Mobile Number";
            let pinLength = provider === 'Nagad' ? '4' : '5';
            document.getElementById('mobileTitle2').innerText = provider + " PIN (" + pinLength + " digits)";
            
            document.getElementById('mobileModal1').style.display = 'flex';
        }

        function nextMobileModal(step) {
            hideErrors();
            if (step === 2) {
                let num = document.getElementById('mobileNum').value;
                if (!num || isNaN(num) || (num.length !== 10 && num.length !== 11)) {
                    let err = document.getElementById('mobileNumErr');
                    err.innerText = "Must be 10 or 11 digits";
                    err.style.display = 'block';
                    return;
                }
                if (/^(\d)\1+$/.test(num)) {
                    let err = document.getElementById('mobileNumErr');
                    err.innerText = "Invalid number";
                    err.style.display = 'block';
                    return;
                }
                document.getElementById('mobileModal1').style.display = 'none';
                document.getElementById('mobileModal2').style.display = 'flex';
            }
            else if (step === 3) {
                let pin = document.getElementById('mobilePin').value;
                let requiredLen = currentProvider === 'Nagad' ? 4 : 5;
                if (!pin || pin.length !== requiredLen || isNaN(pin)) {
                    document.getElementById('mobilePinErr').style.display = 'block';
                    return;
                }
                document.getElementById('mobileModal2').style.display = 'none';
                document.getElementById('mobileModal3').style.display = 'flex';
            }
        }

        function submitMobile() {
            hideErrors();
            let amt = parseFloat(document.getElementById('mobileAmount').value);
            if (!amt || amt <= 0) {
                document.getElementById('mobileAmountErr').style.display = 'block';
                return;
            }
            
            closeModals();
            document.getElementById('hiddenAmount').value = amt;
            processPayment();
        }

        function closeModals() {
            document.getElementById('mobileModal1').style.display = 'none';
            document.getElementById('mobileModal2').style.display = 'none';
            document.getElementById('mobileModal3').style.display = 'none';
        }

        function hideErrors() {
            document.querySelectorAll('.error-msg').forEach(e => e.style.display = 'none');
            document.querySelectorAll('.validation-summary-errors').forEach(e => e.style.display = 'none');
        }

        function handleFormSubmit(e) {
            e.preventDefault();
            hideErrors();
            let isValid = true;
            let finalAmount = 0;

            if (currentMethod === 'Bank') {
                if (!document.getElementById('bankAcc').value) { document.getElementById('bankAccErr').style.display = 'block'; isValid = false; }
                if (!document.getElementById('bankPin').value) { document.getElementById('bankPinErr').style.display = 'block'; isValid = false; }
                finalAmount = parseFloat(document.getElementById('bankAmount').value);
                if (!finalAmount || finalAmount <= 0) { document.getElementById('bankAmountErr').style.display = 'block'; isValid = false; }
            } 
            else if (currentMethod === 'Card') {
                let cardNum = document.getElementById('cardNum').value;
                if (!cardNum || cardNum.length !== 12 || isNaN(cardNum)) { document.getElementById('cardNumErr').style.display = 'block'; isValid = false; }
                
                let dobEl = document.getElementById('cardDob');
                if (dobEl && !dobEl.value) { document.getElementById('cardDobErr').style.display = 'block'; isValid = false; }
                
                if (!document.getElementById('cardPin').value) { document.getElementById('cardPinErr').style.display = 'block'; isValid = false; }
                
                finalAmount = parseFloat(document.getElementById('cardAmount').value);
                if (!finalAmount || finalAmount <= 0) { document.getElementById('cardAmountErr').style.display = 'block'; isValid = false; }
            }

            if (!isValid) return false;

            document.getElementById('hiddenAmount').value = finalAmount;
            processPayment();
        }

        function processPayment() {
            document.getElementById('loadingOverlay').style.display = 'flex';
            setTimeout(() => {
                document.getElementById('addBalanceForm').submit();
            }, 1500); // 1.5s artificial delay for loading animation
        }
    </script>
</body>
</html>
