@model Glitch.ViewModels.Admin.GameFormViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .form-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 30px;
        max-width: 700px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group.full { grid-column: 1 / -1; }

    .form-group label {
        font-size: 13px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        padding: 10px 14px;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: #fff;
        font-size: 14px;
        outline: none;
        transition: border 0.2s;
        font-family: inherit;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus { border-color: var(--primary); }

    .form-group textarea { resize: vertical; min-height: 100px; }

    select option { background: #1a1a2e; }

    .field-error { color: #f87171; font-size: 12px; margin-top: 2px; }

    .image-upload-area {
        border: 2px dashed var(--border);
        border-radius: 10px;
        padding: 24px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s;
        position: relative;
    }

    .image-upload-area:hover { border-color: var(--primary); }

    .image-upload-area input {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
        padding: 0;
        border: none;
        background: transparent;
    }

    .image-upload-area .upload-icon { font-size: 32px; margin-bottom: 8px; }
    .image-upload-area p { font-size: 13px; color: var(--muted); }
    .image-upload-area span { font-size: 11px; color: var(--muted); margin-top: 4px; display: block; }

    #imagePreview {
        width: 100%;
        max-height: 180px;
        object-fit: cover;
        border-radius: 8px;
        margin-top: 12px;
        display: none;
        border: 1px solid var(--border);
    }

    .toggle-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 0;
    }

    .toggle {
        position: relative;
        width: 44px; height: 24px;
    }

    .toggle input { display: none; }

    .toggle-slider {
        position: absolute;
        inset: 0;
        background: var(--border);
        border-radius: 50px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .toggle-slider::before {
        content: '';
        position: absolute;
        width: 18px; height: 18px;
        left: 3px; top: 3px;
        background: #fff;
        border-radius: 50%;
        transition: transform 0.2s;
    }

    .toggle input:checked + .toggle-slider { background: var(--primary); }
    .toggle input:checked + .toggle-slider::before { transform: translateX(20px); }

    .form-actions {
        display: flex;
        gap: 12px;
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

    .btn-save {
        padding: 11px 28px;
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 9px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
    }

    .btn-save:hover { background: var(--primary-dark); }

    .btn-cancel {
        padding: 11px 28px;
        background: transparent;
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: 9px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-cancel:hover { border-color: var(--danger); color: var(--danger); }
</style>

<div class="form-card">
    <form asp-action="AddGame" asp-controller="Admin"
          method="post" enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <div class="form-grid">

            <div class="form-group">
                <label asp-for="Title">Game Title</label>
                <input asp-for="Title" placeholder="e.g. Cyber Legends" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Genre">Select Category</label>
                <input asp-for="Genre" list="genreList" class="form-control" placeholder="Select or type genre" />
                <datalist id="genreList">
                    <option value="Action"></option>
                    <option value="Adventure"></option>
                    <option value="RPG"></option>
                    <option value="Racing"></option>
                    <option value="Horror"></option>
                    <option value="Sports"></option>
                    <option value="Strategy"></option>
                    <option value="Shooter"></option>
                    <option value="Puzzle"></option>
                    <option value="Simulation"></option>
                    <option value="Fighting"></option>
                    <option value="Other"></option>
                </datalist>
            </div>

            <div class="form-group">
                <label asp-for="Price">Price (USD)</label>
                <input asp-for="Price" type="number"
                       step="0.01" min="0.01"
                       placeholder="e.g. 29.99" />
                <span asp-validation-for="Price" class="field-error"></span>
            </div>

            <div class="form-group">
                <label>Availability</label>
                <div class="toggle-row">
                    <label class="toggle">
                        <input asp-for="IsAvailable" type="checkbox" checked />
                        <div class="toggle-slider"></div>
                    </label>
                    <span style="font-size:13px; color:var(--muted);">
                        Show this game to customers
                    </span>
                </div>
            </div>

            <div class="form-group full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description"
                          placeholder="Describe the game..."></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <div class="form-group full">
                <label>Cover Image (optional)</label>
                <div class="image-upload-area" onclick="document.getElementById('imgInput').click()">
                    <input type="file"
                           id="imgInput"
                           name="ImageFile"
                           accept=".jpg,.jpeg,.png,.webp"
                           onchange="previewImage(this)" />
                    <div class="upload-icon">🖼️</div>
                    <p>Click to upload game cover image</p>
                    <span>JPG, PNG or WEBP — max 5MB</span>
                    <img id="imagePreview" src="" alt="Preview" />
                </div>
            </div>

            <div class="form-group full">
                <label>Game File (zip, exe, pdf, docs, images, etc.)</label>
                <div class="image-upload-area" style="border-color: rgba(16,185,129,0.3);">
                    <input type="file"
                           id="gameFileInput"
                           name="GameFileUpload"
                           accept=".zip,.rar,.exe,.msi,.7z,.tar,.gz,.pdf,.doc,.docx,.jpg,.jpeg,.png,.webp" />
                    <div class="upload-icon">📦</div>
                    <p>Click to upload the game file, document, or image</p>
                    <span>ZIP, RAR, EXE, PDF, DOCX, Images — Max 2GB</span>
                    <span id="gameFileName" style="color:#6ee7b7; margin-top:6px; display:none;"></span>
                </div>
            </div>

            <div class="form-group full">
                <label>Additional Screenshots (optional)</label>
                <div class="image-upload-area" style="border-color: rgba(99,102,241,0.3);">
                    <input type="file"
                           id="screenshotsInput"
                           name="ScreenshotFiles"
                           accept=".jpg,.jpeg,.png,.webp" multiple />
                    <div class="upload-icon">📸</div>
                    <p>Click to upload multiple screenshots</p>
                    <span>JPG, PNG or WEBP — max 5MB each</span>
                    <span id="screenshotsNames" style="color:#a5b4fc; margin-top:6px; display:none;"></span>
                </div>
            </div>

            <div class="form-group full" style="margin-top:20px; border-bottom:1px solid var(--border); padding-bottom:10px;">
                <h3 style="font-size:16px; color:#fff;">⚙️ System Requirements (Optional)</h3>
            </div>

            <div class="form-group">
                <label asp-for="ReqSize">Game Size</label>
                <input asp-for="ReqSize" placeholder="e.g. 50 GB" />
            </div>

            <div class="form-group">
                <label asp-for="ReqOS">Operating System</label>
                <input asp-for="ReqOS" placeholder="e.g. Windows 10/11 64-bit" />
            </div>

            <div class="form-group">
                <label asp-for="ReqProcessor">Processor</label>
                <input asp-for="ReqProcessor" placeholder="e.g. Intel Core i5 / AMD Ryzen 5" />
            </div>

            <div class="form-group">
                <label asp-for="ReqMemory">Memory</label>
                <input asp-for="ReqMemory" placeholder="e.g. 16 GB RAM" />
            </div>

            <div class="form-group">
                <label asp-for="ReqGraphics">Graphics</label>
                <input asp-for="ReqGraphics" placeholder="e.g. NVIDIA RTX 3060 / AMD RX 6600" />
            </div>

            <div class="form-group">
                <label asp-for="ReqStorage">Storage Type</label>
                <input asp-for="ReqStorage" placeholder="e.g. SSD recommended" />
            </div>

            <div class="form-group full">
                <label asp-for="TrailerUrl">YouTube Trailer URL (optional)</label>
                <input asp-for="TrailerUrl"
                       placeholder="e.g. https://www.youtube.com/watch?v=XXXXXXX" />
                <span style="font-size:12px; color:var(--muted); margin-top:4px;">
                    Paste any YouTube link — we'll convert it automatically
                </span>
            </div>

        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save">💾 Save Game</button>
            <a href="/Admin/Games" class="btn-cancel">Cancel</a>
        </div>

    </form>
</div>

@section Scripts {
<script>
    // Show image preview when file is selected
    function previewImage(input) {
        const preview = document.getElementById('imagePreview');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                preview.src = e.target.result;
                preview.style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    // Show selected game filename
    document.getElementById('gameFileInput')?.addEventListener('change', function() {
        const label = document.getElementById('gameFileName');
        if (this.files[0]) {
            label.textContent = '✅ Selected: ' + this.files[0].name;
            label.style.display = 'block';
        }
    });

    // Show multiple screenshots names
    document.getElementById('screenshotsInput')?.addEventListener('change', function() {
        const label = document.getElementById('screenshotsNames');
        if (this.files && this.files.length > 0) {
            label.textContent = '✅ Selected ' + this.files.length + ' image(s)';
            label.style.display = 'block';
        } else {
            label.style.display = 'none';
        }
    });
</script>
}