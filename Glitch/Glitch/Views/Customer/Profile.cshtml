@model Glitch.ViewModels.CustomerProfileViewModel

@{
    ViewData["Title"] = "My Profile";
    Layout = null;
    var username = Context.Session.GetString("Username") ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Profile — Glitch</title>
    <style>

        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --bg: #0f0f1a;
            --card: #1a1a2e;
            --border: #2a2a4a;
            --text: #fff;
            --muted: #888;
            --danger: #ef4444;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
        }

        /* Navbar */
        .navbar {
            position: fixed; top: 0; left: 0; width: 100%;
            z-index: 1000;
            display: flex; align-items: center;
            justify-content: space-between;
            padding: 14px 40px;
            background: rgba(15,15,26,0.92);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
        }

        .navbar-logo {
            font-size: 20px; font-weight: 800;
            color: var(--primary); text-decoration: none;
        }

        .navbar-logo span { color: #fff; }

        .navbar-actions { display: flex; gap: 10px; align-items: center; }

        .user-btn {
            display: flex; align-items: center; gap: 8px;
            padding: 7px 14px;
            background: rgba(99,102,241,0.1);
            border: 1px solid rgba(99,102,241,0.2);
            border-radius: 50px;
            text-decoration: none; color: #fff;
            font-size: 13px; font-weight: 600;
        }

        .user-avatar-small {
            width: 26px; height: 26px; border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), #8b5cf6);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; overflow: hidden;
        }

        .user-avatar-small img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

        .btn-outline {
            padding: 8px 18px;
            border: 1px solid var(--primary); color: var(--primary);
            background: transparent; border-radius: 8px;
            font-size: 13px; font-weight: 600;
            text-decoration: none; transition: all 0.2s;
        }

        .btn-outline:hover { background: var(--primary); color: #fff; }

        /* Page content */
        .page-wrap {
            max-width: 960px;
            margin: 0 auto;
            padding: 100px 30px 60px;
        }

        .page-title {
            font-size: 24px; font-weight: 800;
            margin-bottom: 6px;
        }

        .page-sub {
            font-size: 14px; color: var(--muted);
            margin-bottom: 30px;
        }

        /* Toast */
        .alert-success {
            background: #064e3b; border: 1px solid #059669;
            color: #6ee7b7; padding: 12px 16px;
            border-radius: 10px; font-size: 14px;
            margin-bottom: 20px;
        }

        .alert-danger {
            background: #450a0a; border: 1px solid #dc2626;
            color: #fca5a5; padding: 12px 16px;
            border-radius: 10px; font-size: 14px;
            margin-bottom: 20px;
        }

        /* Profile layout */
        .profile-layout {
            display: grid;
            grid-template-columns: 260px 1fr;
            gap: 24px;
        }

        /* Avatar card */
        .avatar-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 28px 20px;
            display: flex; flex-direction: column;
            align-items: center; gap: 12px;
            text-align: center;
            height: fit-content;
        }

        .big-avatar {
            width: 96px; height: 96px; border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), #8b5cf6);
            display: flex; align-items: center; justify-content: center;
            font-size: 38px; font-weight: 800;
            overflow: hidden;
            border: 3px solid rgba(99,102,241,0.3);
        }

        .big-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

        .avatar-name { font-size: 17px; font-weight: 800; }

        .avatar-role {
            font-size: 12px; font-weight: 700;
            background: rgba(16,185,129,0.15);
            color: #6ee7b7;
            padding: 3px 12px; border-radius: 50px;
        }

        .avatar-upload {
            width: 100%; padding: 8px;
            border: 1px dashed var(--border);
            border-radius: 8px; text-align: center;
            font-size: 12px; color: var(--muted);
            cursor: pointer; transition: border-color 0.2s;
            position: relative;
        }

        .avatar-upload:hover { border-color: var(--primary); color: var(--primary); }
        .avatar-upload input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }

        /* Form card */
        .form-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
        }

        .form-section {
            padding: 24px 28px;
            border-bottom: 1px solid var(--border);
        }

        .form-section:last-child { border-bottom: none; }

        .form-section h3 {
            font-size: 15px; font-weight: 800;
            margin-bottom: 18px;
            display: flex; align-items: center; gap: 8px;
        }

        .form-group { margin-bottom: 16px; }
        .form-group:last-of-type { margin-bottom: 0; }

        .form-group label {
            display: block; font-size: 12px; font-weight: 700;
            color: var(--muted); text-transform: uppercase;
            letter-spacing: 0.5px; margin-bottom: 6px;
        }

        .form-group input {
            width: 100%; padding: 10px 14px;
            background: var(--bg); border: 1px solid var(--border);
            border-radius: 8px; color: #fff;
            font-size: 14px; outline: none; transition: border 0.2s;
        }

        .form-group input:focus { border-color: var(--primary); }
        .field-error { color: #f87171; font-size: 12px; margin-top: 4px; display: block; }

        .password-note {
            font-size: 12px; color: var(--muted);
            padding: 10px 14px;
            background: rgba(99,102,241,0.08);
            border-radius: 8px;
            border-left: 3px solid var(--primary);
            margin-bottom: 16px;
        }

        .btn-save {
            padding: 10px 26px;
            background: var(--primary); color: #fff;
            border: none; border-radius: 9px;
            font-size: 14px; font-weight: 700;
            cursor: pointer; transition: background 0.2s;
            margin-top: 16px;
        }

        .btn-save:hover { background: var(--primary-dark); }

        /* Danger zone */
        .danger-zone {
            background: rgba(239,68,68,0.05);
            border: 1px solid rgba(239,68,68,0.2);
            border-radius: 14px;
            padding: 24px 28px;
            margin-top: 24px;
        }

        .danger-zone h3 {
            font-size: 15px; font-weight: 800;
            color: var(--danger);
            margin-bottom: 8px;
            display: flex; align-items: center; gap: 8px;
        }

        .danger-zone p {
            font-size: 13px; color: var(--muted);
            margin-bottom: 16px; line-height: 1.6;
        }

        .btn-danger {
            padding: 10px 24px;
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.4);
            color: #fca5a5;
            border-radius: 9px;
            font-size: 14px; font-weight: 700;
            cursor: pointer; text-decoration: none;
            transition: all 0.2s;
        }

        .btn-danger:hover { background: var(--danger); color: #fff; border-color: var(--danger); }

    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <a href="/" class="navbar-logo">🎮 Game<span>Vault</span></a>
        <div class="navbar-actions">
            <a href="/Customer/Profile" class="user-btn">
                <div class="user-avatar-small">
                    @{
                        var profileImg = Context.Session.GetString("ProfileImage");
                    }
                    @if (!string.IsNullOrEmpty(profileImg))
                    {
                        <img src="/uploads/profiles/@profileImg" alt="@username" />
                    }
                    else
                    {
                        @username.Substring(0, 1).ToUpper()
                    }
                </div>
                @username
            </a>
            <a href="/Account/Logout" class="btn-outline">Logout</a>
        </div>
    </nav>

    <div class="page-wrap">

        <div class="page-title">👤 My Profile</div>
        <div class="page-sub">Manage your account settings</div>

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">✅ @TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert-danger">❌ @TempData["Error"]</div>
        }

        <form asp-action="Profile" asp-controller="Customer"
              method="post" enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <div class="profile-layout">

                <!-- Avatar card -->
                <div class="avatar-card">
                    <div class="big-avatar" id="avatarPreview">
                        @if (!string.IsNullOrEmpty(Model.ProfileImage))
                        {
                            <img id="avatarImg"
                                 src="/uploads/profiles/@Model.ProfileImage"
                                 alt="@username" />
                        }
                        else
                        {
                            <span id="avatarInitial">
                                @username.Substring(0, 1).ToUpper()
                            </span>
                        }
                    </div>

                    <div class="avatar-name">@username</div>
                    <div class="avatar-role">👤 Customer</div>

                    <div class="avatar-upload">
                        <input type="file"
                               name="ImageFile"
                               accept=".jpg,.jpeg,.png,.webp"
                               onchange="previewAvatar(this)" />
                        📷 Change Photo
                    </div>

                    <span style="font-size:11px; color:var(--muted);">
                        JPG, PNG or WEBP · Max 3MB
                    </span>
                </div>

                <!-- Form card -->
                <div class="form-card">

                    <!-- Basic info -->
                    <div class="form-section">
                        <h3>👤 Basic Information</h3>

                        <div class="form-group">
                            <label asp-for="Username">Username</label>
                            <input asp-for="Username" />
                            <span asp-validation-for="Username" class="field-error"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email">Email Address</label>
                            <input asp-for="Email" type="email" />
                            <span asp-validation-for="Email" class="field-error"></span>
                        </div>

                        <button type="submit" class="btn-save">💾 Save Changes</button>
                    </div>

                    <!-- Change password -->
                    <div class="form-section">
                        <h3>🔒 Change Password</h3>

                        <div class="password-note">
                            Leave blank if you don't want to change your password.
                        </div>

                        <div class="form-group">
                            <label asp-for="CurrentPassword">Current Password</label>
                            <input asp-for="CurrentPassword" placeholder="Enter current password" />
                            <span asp-validation-for="CurrentPassword" class="field-error"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="NewPassword">New Password</label>
                            <input asp-for="NewPassword" placeholder="Min 6 characters" />
                            <span asp-validation-for="NewPassword" class="field-error"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="ConfirmNewPassword">Confirm New Password</label>
                            <input asp-for="ConfirmNewPassword" placeholder="Repeat new password" />
                            <span asp-validation-for="ConfirmNewPassword" class="field-error"></span>
                        </div>

                        <button type="submit" class="btn-save">🔒 Update Password</button>
                    </div>

                </div>
            </div>

        </form>

        <!-- Danger Zone -->
        <div class="danger-zone">
            <h3>⚠️ Danger Zone</h3>
            <p>
                Once you delete your account, there is no going back.
                All your purchases, cart items, and favorites will be
                permanently deleted from our database.
            </p>
            <a href="/Customer/DeleteAccount" class="btn-danger">
                🗑️ Delete My Account
            </a>
        </div>

    </div>

    <script>
        function previewAvatar(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    const preview = document.getElementById('avatarPreview');
                    const initial = document.getElementById('avatarInitial');
                    if (initial) initial.remove();
                    let img = document.getElementById('avatarImg');
                    if (!img) {
                        img = document.createElement('img');
                        img.id = 'avatarImg';
                        img.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:50%;';
                        preview.appendChild(img);
                    }
                    img.src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>

</body>
</html>