@model Glitch.ViewModels.LibraryViewModel

@{
    ViewData["Title"] = "My Library";
    Layout = null; // matching Profile layout logic
    var username = Context.Session.GetString("Username") ?? "";
    var profileImg = Context.Session.GetString("ProfileImage");
}
@inject Glitch.Data.AppDbContext DbContext

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Library — Glitch</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --bg: #0f0f1a;
            --card: #1a1a2e;
            --border: #2a2a4a;
            --text: #fff;
            --muted: #888;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
        }

        /* Navbar */
        .navbar {
            position: fixed; top: 0; left: 0; width: 100%;
            z-index: 1000;
            display: flex; align-items: center;
            justify-content: space-between;
            padding: 14px 40px;
            background: rgba(15,15,26,0.92);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
        }

        .navbar-logo {
            font-size: 20px; font-weight: 800;
            color: var(--primary); text-decoration: none;
        }

        .navbar-logo span { color: #fff; }
        .navbar-actions { display: flex; gap: 10px; align-items: center; }

        .user-btn {
            display: flex; align-items: center; gap: 8px;
            padding: 7px 14px;
            background: rgba(99,102,241,0.1);
            border: 1px solid rgba(99,102,241,0.2);
            border-radius: 50px;
            text-decoration: none; color: #fff;
            font-size: 13px; font-weight: 600;
        }

        .user-avatar-small {
            width: 26px; height: 26px; border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), #8b5cf6);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; overflow: hidden;
        }

        .user-avatar-small img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

        .btn-outline {
            padding: 8px 18px;
            border: 1px solid var(--primary); color: var(--primary);
            background: transparent; border-radius: 8px;
            font-size: 13px; font-weight: 600;
            text-decoration: none; transition: all 0.2s;
        }
        .btn-outline:hover { background: var(--primary); color: #fff; }

        /* Page content */
        .page-wrap {
            max-width: 1200px;
            margin: 0 auto;
            padding: 100px 30px 60px;
        }

        .page-title {
            font-size: 28px; font-weight: 800;
            margin-bottom: 6px;
        }
        .page-sub {
            font-size: 15px; color: var(--muted);
            margin-bottom: 40px;
        }

        .tabs {
            display: flex; gap: 16px; margin-bottom: 30px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 10px;
        }
        .tab {
            font-size: 16px; font-weight: 700; color: var(--muted);
            cursor: pointer; padding: 10px 20px; border-radius: 8px;
            transition: all 0.2s;
        }
        .tab:hover { color: #fff; background: rgba(99,102,241,0.1); }
        .tab.active { color: var(--primary); background: rgba(99,102,241,0.15); }

        .tab-content { display: none; }
        .tab-content.active { display: block; }

        .game-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 24px;
        }

        .game-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 12px; overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .game-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 40px rgba(99,102,241,0.2);
            border-color: var(--primary);
        }
        .game-thumb { width: 100%; height: 160px; object-fit: cover; }
        .game-thumb-placeholder {
            width: 100%; height: 160px; background: linear-gradient(135deg, #2a2a4a, #1a1a2e);
            display: flex; align-items: center; justify-content: center; font-size: 40px;
        }
        .game-info { padding: 16px; }
        .game-title { font-size: 15px; font-weight: 700; margin-bottom: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .game-genre { font-size: 12px; color: var(--muted); margin-bottom: 12px; }
        .game-actions { display: flex; gap: 8px; }

        .btn-action {
            flex: 1; padding: 8px; text-align: center; border-radius: 8px;
            font-size: 13px; font-weight: 700; cursor: pointer; text-decoration: none; border: none;
        }
        .btn-play { background: var(--primary); color: #fff; }
        .btn-play:hover { background: var(--primary-dark); }
        .btn-remove { background: rgba(239,68,68,0.1); color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
        .btn-remove:hover { background: #ef4444; color: #fff; }

        .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
        .empty-state h3 { font-size: 20px; font-weight: 700; color: #fff; margin-bottom: 10px; }
        .empty-state p { font-size: 14px; margin-bottom: 20px; }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/" class="navbar-logo">🎮 The<span>Glitch</span></a>
        <div class="navbar-actions">
            @{
                decimal navBalance = 0;
                var userIdStr = Context.Session.GetString("UserId");
                if (!string.IsNullOrEmpty(userIdStr))
                {
                    var navUser = await DbContext.Users.FindAsync(int.Parse(userIdStr));
                    if (navUser != null) navBalance = navUser.Balance;
                }
                var navUsername = Context.Session.GetString("Username") ?? "";
                var navProfileImg = Context.Session.GetString("ProfileImage");
            }
            <a href="/Customer/AddBalance" class="btn-outline" style="border-color:#10b981; color:#10b981; font-weight:800; display:flex; align-items:center; gap:6px;">
                <span>💰</span> $@navBalance.ToString("0.00")
            </a>
            <a href="/Customer/Profile" style="display:flex;align-items:center;gap:8px;padding:7px 14px;background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.2);border-radius:50px;text-decoration:none;color:#fff;font-size:13px;font-weight:600;">
                <div style="width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;overflow:hidden;">
                    @if (!string.IsNullOrEmpty(navProfileImg))
                    {
                        <img src="/uploads/profiles/@navProfileImg" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                    }
                    else
                    {
                        @navUsername.Substring(0, 1).ToUpper()
                    }
                </div>
                @navUsername
            </a>
            @if (Context.Session.GetString("Role") == "Admin")
            {
                <a href="/Admin/Index" class="btn-outline">⚙️ Admin Panel</a>
            }
            <a href="/Customer/Library" class="btn-outline">📚 Library</a>
            <a href="/Account/Logout" class="btn-outline">Logout</a>
        </div>
    </nav>

    <div class="page-wrap">
        <div class="page-title">📚 My Library</div>
        <div class="page-sub">Manage your downloaded games and wishlist</div>

        <div class="tabs">
            <div class="tab active" onclick="switchTab('downloads', this)">⬇️ Downloaded Games</div>
            <div class="tab" onclick="switchTab('wishlist', this)">❤️ Wishlist</div>
        </div>

        <div id="downloads" class="tab-content active">
            @if (TempData["RefundError"] != null)
            {
                <div style="background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); color:#f87171; padding:12px 20px; border-radius:8px; margin-bottom:20px;">
                    @TempData["RefundError"]
                </div>
            }
            @if (TempData["Success"] != null)
            {
                <div style="background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.3); color:#34d399; padding:12px 20px; border-radius:8px; margin-bottom:20px;">
                    @TempData["Success"]
                </div>
            }

            @if (Model.PurchasedGames.Any())
            {
                <div class="game-grid">
                    @foreach (var game in Model.PurchasedGames)
                    {
                        <div class="game-card">
                            @if (!string.IsNullOrEmpty(game.ImageFileName))
                            {
                                <img class="game-thumb" src="/uploads/games/@game.ImageFileName" />
                            }
                            else
                            {
                                <div class="game-thumb-placeholder">🎮</div>
                            }
                            <div class="game-info">
                                <div class="game-title" title="@game.Title">@game.Title</div>
                                <div class="game-genre">@game.Genre</div>
                                <div class="game-actions">
                                    <a href="/Home/GameDetail/@game.Id" class="btn-action btn-play" style="background: rgba(99,102,241,0.1); color: var(--primary); border: 1px solid var(--primary);">View Details</a>
                                    <form action="/Customer/RefundGame" method="post" style="flex: 1; display: flex;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="gameId" value="@game.Id" />
                                        <button type="submit" class="btn-action btn-remove" style="width: 100%;">Refund</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <h3>No Downloads Yet</h3>
                    <p>You haven't purchased any games yet. Head to the store to find something amazing!</p>
                    <a href="/" class="btn-outline" style="display:inline-block; padding: 10px 24px;">Browse Games</a>
                </div>
            }
        </div>

        <div id="wishlist" class="tab-content">
            @if (Model.WishlistGames.Any())
            {
                <div class="game-grid">
                    @foreach (var game in Model.WishlistGames)
                    {
                        <div class="game-card" id="wishlist-game-@game.Id">
                            @if (!string.IsNullOrEmpty(game.ImageFileName))
                            {
                                <img class="game-thumb" src="/uploads/games/@game.ImageFileName" />
                            }
                            else
                            {
                                <div class="game-thumb-placeholder">🎮</div>
                            }
                            <div class="game-info">
                                <div class="game-title" title="@game.Title">@game.Title</div>
                                <div class="game-genre">@game.Genre</div>
                                <div class="game-actions">
                                    <a href="/Home/GameDetail/@game.Id" class="btn-action btn-play">View</a>
                                    <button onclick="removeWishlist(@game.Id)" class="btn-action btn-remove">Remove</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <h3>Your Wishlist is Empty</h3>
                    <p>Found a game you like but not ready to buy? Add it to your wishlist!</p>
                    <a href="/" class="btn-outline" style="display:inline-block; padding: 10px 24px;">Browse Games</a>
                </div>
            }
        </div>
    </div>

    <script>
        function switchTab(tabId, element) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            element.classList.add('active');
            document.getElementById(tabId).classList.add('active');
        }

        async function removeWishlist(gameId) {
            try {
                const res = await fetch('/Customer/ToggleWishlist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `gameId=${gameId}`
                });
                const data = await res.json();
                if (data.success && !data.added) {
                    const card = document.getElementById('wishlist-game-' + gameId);
                    if (card) {
                        card.style.display = 'none';
                    }
                }
            } catch (err) {
                console.error('Failed to update wishlist', err);
            }
        }
    </script>
</body>
</html>
