        ];

        // ═══════════════════════════════════════════════════════
        // SEARCH LOGIC
        // ═══════════════════════════════════════════════════════
        let searchTimeout;

        function handleSearch(query) {
            // Clear previous timeout - prevents searching on every keystroke
            clearTimeout(searchTimeout);

            // Wait 200ms after user stops typing before searching
            searchTimeout = setTimeout(() => {
                const dropdown = document.getElementById('searchDropdown');
                const q = query.trim().toLowerCase();

                // If empty, close dropdown
                if (q === '') {
                    dropdown.classList.remove('open');
                    dropdown.innerHTML = '';
                    return;
                }

                // Filter games by name, category or price
                const results = allGames.filter(game => {
                    const nameMatch     = game.name.toLowerCase().includes(q);
                    const categoryMatch = game.category.toLowerCase().includes(q);
                    // Price match: user types "29" and it matches "$29.99"
                    const priceMatch    = game.price.toString().includes(q);
                    return nameMatch || categoryMatch || priceMatch;
                });

                // Build dropdown HTML
                if (results.length === 0) {
                    dropdown.innerHTML = `<div class="search-no-results">😕 No games found for "${query}"</div>`;
                } else {
                    dropdown.innerHTML = results.slice(0, 8).map(game => `
                        <div class="search-result-item" onclick="selectGame('${game.name}')">
                            <div class="search-result-icon">${game.emoji}</div>
                            <div class="search-result-info">
                                <div class="search-result-name">${highlightText(game.name, q)}</div>
                                <div class="search-result-meta">
                                    <span>${highlightText(game.category, q)}</span>
                                </div>
                            </div>
                            <div class="search-result-price">$${game.price.toFixed(2)}</div>
                        </div>
                    `).join('');
                }

                dropdown.classList.add('open');
            }, 200);
        }

        // Highlight matching text in search results
        function highlightText(text, query) {
            const regex = new RegExp(`(${query})`, 'gi');
            return text.replace(regex, '<span class="highlight">$1</span>');
        }

        // When user clicks a search result
        function selectGame(name) {
            document.getElementById('searchInput').value = name;
            document.getElementById('searchDropdown').classList.remove('open');
            // Scroll to games section
            document.getElementById('games').scrollIntoView({ behavior: 'smooth' });
        }

        // Show dropdown when input is focused
        function showDropdown() {
            const q = document.getElementById('searchInput').value.trim();
            if (q !== '') {
                document.getElementById('searchDropdown').classList.add('open');
            }
        }

        // Hide dropdown when input loses focus (small delay so click registers)
        function hideDropdown() {
            setTimeout(() => {
                document.getElementById('searchDropdown').classList.remove('open');
            }, 200);
        }

        // ═══════════════════════════════════════════════════════
        // HERO SLIDER
        // ═══════════════════════════════════════════════════════
        const slides    = document.querySelectorAll('.slide');
        const dots      = document.querySelectorAll('.dot');
        const progress  = document.getElementById('sliderProgress');
        let current     = 0;
        let timer;
        const duration  = 5000;

        function goToSlide(index) {
            slides[current].classList.remove('active');
            slides[current].classList.add('exit');
            const exiting = slides[current];
            setTimeout(() => exiting.classList.remove('exit'), 700);
            dots[current].classList.remove('active');
            current = index;
            slides[current].classList.add('active');
            dots[current].classList.add('active');
            // Reset progress bar
            progress.style.animation = 'none';
            progress.offsetHeight;
            progress.style.animation = `progressBar ${duration/1000}s linear`;
        }

        function nextSlide() { goToSlide((current + 1) % slides.length); }
        function prevSlide() { goToSlide((current - 1 + slides.length) % slides.length); }

        function resetTimer() { clearInterval(timer); timer = setInterval(nextSlide, duration); }
        function startTimer() { timer = setInterval(nextSlide, duration); }

        // Override goToSlide to also reset timer
        const _goToSlide = goToSlide;

        startTimer();

        // ═══════════════════════════════════════════════════════
        // CATEGORY FILTER
        // ═══════════════════════════════════════════════════════
        function filterCategory(category, btn) {
            // Update active tab
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');

            const blocks = document.querySelectorAll('.category-block');

            if (category === 'all') {
                blocks.forEach(b => b.classList.add('visible'));
            } else {
                blocks.forEach(b => b.classList.remove('visible'));
                const target = document.getElementById('cat-' + category);
                if (target) target.classList.add('visible');
            }

            document.getElementById('games').scrollIntoView({ behavior: 'smooth' });
        }

        // ═══════════════════════════════════════════════════════
        // ROW SCROLL (arrow buttons)
        // ═══════════════════════════════════════════════════════
        function scrollRow(rowId, amount) {
            const row = document.getElementById(rowId);
            // Smooth scroll the row left or right by amount pixels
            row.scrollBy({ left: amount, behavior: 'smooth' });
        }

        // ═══════════════════════════════════════════════════════
        // DRAG TO SCROLL (mouse drag on rows)
        // ═══════════════════════════════════════════════════════
        document.querySelectorAll('.games-row').forEach(row => {

            let isDown    = false;   // Is mouse button held down?
            let startX;              // Where the drag started
            let scrollLeft;          // How far row was scrolled when drag started

            // Mouse pressed down on row
            row.addEventListener('mousedown', e => {
                isDown = true;
                row.classList.add('dragging');
                startX     = e.pageX - row.offsetLeft;
                scrollLeft = row.scrollLeft;
            });

            // Mouse released anywhere
            row.addEventListener('mouseleave', () => {
                isDown = false;
                row.classList.remove('dragging');
            });

            row.addEventListener('mouseup', () => {
                isDown = false;
                row.classList.remove('dragging');
            });

            // Mouse moving while held down = drag scroll
            row.addEventListener('mousemove', e => {
                if (!isDown) return;
                e.preventDefault();
                const x    = e.pageX - row.offsetLeft;
                const walk = (x - startX) * 2; // multiply for faster scroll
                row.scrollLeft = scrollLeft - walk;
            });

            // Touch support for mobile
            let touchStartX;
            let touchScrollLeft;

            row.addEventListener('touchstart', e => {
                touchStartX    = e.touches[0].pageX - row.offsetLeft;
                touchScrollLeft = row.scrollLeft;
            });

            row.addEventListener('touchmove', e => {
                const x    = e.touches[0].pageX - row.offsetLeft;
                const walk = (x - touchStartX) * 2;
                row.scrollLeft = touchScrollLeft - walk;
            });

        });

    </script>

</body>
</html>