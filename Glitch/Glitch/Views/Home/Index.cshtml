@model List<Glitch.Models.Entities.Game>
@inject Glitch.Data.AppDbContext DbContext

@{
    ViewData["Title"] = "Glitch - Home";
    Layout = null;

    // Get unique genres from database games
    var genres = Model.Select(g => g.Genre).Distinct().OrderBy(g => g).ToList();

    List<int> ownedGameIds = new List<int>();
    decimal navBalance = 0;
    if (Context.Session.GetString("UserId") != null)
    {
        var userId = int.Parse(Context.Session.GetString("UserId")!);
        ownedGameIds = DbContext.Purchases.Where(p => p.UserId == userId).Select(p => p.GameId).ToList();
        var navUser = await DbContext.Users.FindAsync(userId);
        if (navUser != null) navBalance = navUser.Balance;
    }

    // Genre emoji map
    var genreEmoji = new Dictionary<string, string>
    {
        {"Action", "💥"}, {"Adventure", "🌍"}, {"RPG", "🧙"},
        {"Racing", "🏎️"}, {"Horror", "👻"}, {"Sports", "⚽"},
        {"Strategy", "♟️"}, {"Shooter", "🔫"}, {"Puzzle", "🧩"},
        {"Simulation", "🏙️"}, {"Fighting", "🥊"}, {"Other", "🎮"}
    };

    // Genre color theme map
    var genreTheme = new Dictionary<string, string>
    {
        {"Action", "#f43f5e"}, {"Adventure", "#10b981"}, {"RPG", "#8b5cf6"},
        {"Racing", "#f59e0b"}, {"Horror", "#374151"}, {"Sports", "#3b82f6"},
        {"Strategy", "#0891b2"}, {"Shooter", "#dc2626"}, {"Puzzle", "#ec4899"},
        {"Simulation", "#14b8a6"}, {"Fighting", "#f97316"}, {"Other", "#6366f1"}
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Glitch — Your Game Store</title>
    <style>

        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --bg: #0f0f1a;
            --card-bg: #1a1a2e;
            --border: #2a2a4a;
            --text: #ffffff;
            --text-muted: #888;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', sans-serif;
            overflow-x: hidden;
        }

        /* ── Navbar ───────────────────────────────────────────── */
        .navbar {
            position: fixed;
            top: 0; left: 0;
            width: 100%;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 40px;
            background: rgba(15,15,26,0.92);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            gap: 16px;
        }

        .navbar-logo {
            font-size: 20px;
            font-weight: 800;
            color: var(--primary);
            text-decoration: none;
            letter-spacing: 1px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .navbar-logo span { color: #fff; }

        /* Search + Filter bar */
        .navbar-search {
            flex: 1;
            max-width: 500px;
            position: relative;
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .search-input-wrap {
            position: relative;
            flex: 1;
        }

        .search-input-wrap input {
            width: 100%;
            padding: 9px 16px 9px 40px;
            background: rgba(42,42,74,0.6);
            border: 1px solid var(--border);
            border-radius: 50px;
            color: #fff;
            font-size: 14px;
            outline: none;
            transition: border 0.2s;
        }

        .search-input-wrap input::placeholder { color: var(--text-muted); }
        .search-input-wrap input:focus { border-color: var(--primary); }

        .search-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
            pointer-events: none;
        }

        /* Filter dropdown button */
        .filter-btn {
            padding: 9px 14px;
            background: rgba(42,42,74,0.6);
            border: 1px solid var(--border);
            border-radius: 50px;
            color: var(--text-muted);
            font-size: 13px;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .filter-btn:hover,
        .filter-btn.active {
            border-color: var(--primary);
            color: var(--primary);
        }

        /* Filter panel dropdown */
        .filter-panel {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            background: #1a1a2e;
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px;
            width: 280px;
            z-index: 9999;
            box-shadow: 0 20px 60px rgba(0,0,0,0.6);
            display: none;
        }

        .filter-panel.open { display: block; }

        .filter-panel h4 {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .filter-section { margin-bottom: 18px; }

        .filter-options {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .filter-chip {
            padding: 5px 12px;
            border-radius: 50px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-muted);
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .filter-chip:hover,
        .filter-chip.selected {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        .filter-actions {
            display: flex;
            gap: 8px;
            margin-top: 4px;
        }

        .btn-apply-filter {
            flex: 1;
            padding: 8px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-apply-filter:hover { background: var(--primary-dark); }

        .btn-clear-filter {
            padding: 8px 14px;
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-clear-filter:hover { border-color: #f43f5e; color: #f43f5e; }

        /* Search dropdown results */
        .search-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            width: calc(100% - 110px);
            background: #1a1a2e;
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            z-index: 9999;
            display: none;
            max-height: 360px;
            overflow-y: auto;
        }

        .search-dropdown.open { display: block; }

        .search-result-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 16px;
            cursor: pointer;
            border-bottom: 1px solid rgba(42,42,74,0.5);
            transition: background 0.15s;
        }

        .search-result-item:last-child { border-bottom: none; }
        .search-result-item:hover { background: rgba(99,102,241,0.1); }

        .search-result-icon {
            width: 38px; height: 38px;
            background: var(--bg);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
            overflow: hidden;
        }

        .search-result-icon img {
            width: 100%; height: 100%;
            object-fit: cover;
            border-radius: 8px;
        }

        .search-result-info { flex: 1; }

        .search-result-name {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .search-result-genre {
            font-size: 11px;
            color: var(--text-muted);
        }

        .search-result-price {
            font-size: 13px;
            font-weight: 800;
            color: var(--primary);
        }

        .highlight { color: var(--primary); font-weight: 800; }

        .search-no-results {
            padding: 20px;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
        }

        /* Navbar actions */
        .navbar-actions {
            display: flex;
            gap: 10px;
            flex-shrink: 0;
        }

        .btn-outline {
            padding: 8px 18px;
            border: 1px solid var(--primary);
            color: var(--primary);
            background: transparent;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-outline:hover { background: var(--primary); color: #fff; }

        .btn-filled {
            padding: 8px 18px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.2s;
        }

        .btn-filled:hover { background: var(--primary-dark); }

        /* ── Hero Slider ──────────────────────────────────────── */
        .hero-slider {
            position: relative;
            width: 100%;
            height: 100vh;
            overflow: hidden;
        }

        .slide {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 80px;
            opacity: 0;
            transform: translateX(100%);
            transition: transform 0.7s cubic-bezier(0.77,0,0.175,1), opacity 0.7s ease;
            z-index: 1;
        }

        .slide.active { opacity: 1; transform: translateX(0); z-index: 2; }
        .slide.exit   { opacity: 0; transform: translateX(-100%); z-index: 1; }

        .slide-bg {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            z-index: 0;
            opacity: 1;
            filter: none;
        }

        .slide-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to right,rgba(15,15,26,0.75) 50%);
            z-index: 1;
        }

        .slide-content { position: relative; z-index: 3; max-width: 520px; }

        .slide-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(99,102,241,0.15);
            border: 1px solid rgba(99,102,241,0.3);
            color: var(--primary);
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .slide-title {
            font-size: clamp(36px, 5vw, 64px);
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 16px;
            background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .slide-description {
            font-size: 15px;
            color: var(--text-muted);
            line-height: 1.7;
            margin-bottom: 28px;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .slide-meta { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; flex-wrap: wrap; }
        .slide-price { font-size: 28px; font-weight: 800; color: var(--primary); }
        .slide-genre { font-size: 12px; background: var(--border); color: var(--text-muted); padding: 4px 12px; border-radius: 50px; }
        .slide-buttons { display: flex; gap: 12px; }

        .btn-buy {
            padding: 12px 28px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
            box-shadow: 0 0 24px rgba(99,102,241,0.4);
        }

        .btn-buy:hover { background: var(--primary-dark); transform: translateY(-2px); }

        .btn-wishlist {
            padding: 12px 28px;
            background: transparent;
            color: #fff;
            border: 1px solid var(--border);
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-wishlist:hover, .btn-wishlist.active { border-color: #f43f5e; color: #f43f5e; }

        .slide-image { position: relative; z-index: 3; flex-shrink: 0; }

        .game-cover {
            width: 260px; height: 340px;
            object-fit: cover;
            border-radius: 16px;
            opacity: 0.75;
            box-shadow: 0 0 60px rgba(99,102,241,0.2);
            border: 1px solid rgba(99,102,241,0.15);
        }

        .game-cover-placeholder {
            width: 260px; height: 340px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 72px;
            opacity: 0.6;
            box-shadow: 0 0 60px rgba(99,102,241,0.2);
            border: 1px solid rgba(99,102,241,0.15);
            background: linear-gradient(135deg, #1e1e3a, #2a2a4a);
        }

        .slider-controls {
            position: absolute;
            bottom: 40px; left: 80px;
            z-index: 10;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .slider-dots { display: flex; gap: 8px; }

        .dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--border);
            cursor: pointer;
            transition: all 0.3s;
        }

        .dot.active { background: var(--primary); width: 24px; border-radius: 4px; }

        .arrow-btn {
            width: 36px; height: 36px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: rgba(26,26,46,0.8);
            color: #fff;
            font-size: 15px;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.2s;
        }

        .arrow-btn:hover { border-color: var(--primary); background: var(--primary); }

        .slider-progress {
            position: absolute;
            bottom: 0; left: 0;
            height: 3px;
            background: var(--primary);
            z-index: 10;
            animation: progressBar 5s linear infinite;
        }

        @@keyframes progressBar { 0% { width: 0%; } 100% { width: 100%; } }

        /* ── No Games Hero ────────────────────────────────────── */
        .no-games-hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            flex-direction: column;
            gap: 16px;
        }

        .no-games-hero h1 {
            font-size: 52px;
            font-weight: 900;
            background: linear-gradient(135deg, #fff 0%, #6366f1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .no-games-hero p { font-size: 16px; color: var(--text-muted); }

        /* ── Games Section ────────────────────────────────────── */
        .games-section {
            padding: 80px 40px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-header { margin-bottom: 30px; }
        .section-header h2 { font-size: 22px; font-weight: 800; }
        .section-header p { font-size: 13px; color: var(--text-muted); margin-top: 4px; }

        /* Category tabs */
        .category-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 40px; }

        .tab-btn {
            padding: 8px 18px;
            border-radius: 50px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .tab-btn:hover { border-color: var(--primary); color: var(--primary); }
        .tab-btn.active { background: var(--primary); border-color: var(--primary); color: #fff; }

        /* Category block */
        .category-block { margin-bottom: 60px; display: none; }
        .category-block.visible { display: block; }

        .category-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border);
        }

        .category-title { display: flex; align-items: center; gap: 10px; font-size: 18px; font-weight: 800; }

        .row-arrows { display: flex; gap: 8px; }

        .row-arrow {
            width: 32px; height: 32px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: var(--card-bg);
            color: #fff;
            font-size: 14px;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.2s;
        }

        .row-arrow:hover { border-color: var(--primary); background: var(--primary); }

        .games-row-wrapper { overflow: hidden; }

        .games-row {
            display: flex;
            gap: 18px;
            overflow-x: auto;
            scroll-behavior: smooth;
            padding-bottom: 10px;
            scrollbar-width: none;
        }

        .games-row::-webkit-scrollbar { display: none; }

        /* Game card */
        .game-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
            flex-shrink: 0;
            width: 210px;
        }

        .game-card:hover {
            transform: translateY(-6px);
            border-color: var(--primary);
            box-shadow: 0 12px 40px rgba(99,102,241,0.2);
        }

        .game-card-thumb {
            width: 100%; height: 140px;
            object-fit: cover;
            opacity: 0.85;
        }

        .game-card-thumb-placeholder {
            width: 100%; height: 140px;
            display: flex; align-items: center; justify-content: center;
            font-size: 42px;
            position: relative;
            overflow: hidden;
        }

        .game-card-thumb-placeholder .emoji {
            position: relative;
            z-index: 2;
            opacity: 0.8;
        }

        .game-card-body { padding: 12px; }

        .game-card-name {
            font-size: 13px; font-weight: 700;
            margin-bottom: 6px;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }

        .game-card-footer {
            display: flex; align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .game-card-price { font-size: 14px; font-weight: 800; color: var(--primary); }

        .game-card-genre {
            font-size: 11px; color: var(--text-muted);
            background: var(--bg);
            padding: 3px 8px; border-radius: 50px;
        }

        .game-card-actions { display: flex; gap: 6px; }

        .btn-card-buy {
            flex: 1; padding: 7px;
            background: var(--primary); color: #fff;
            border: none; border-radius: 7px;
            font-size: 12px; font-weight: 700;
            cursor: pointer; text-decoration: none;
            text-align: center; transition: background 0.2s;
        }

        .btn-card-buy:hover { background: var(--primary-dark); }

        .btn-card-fav {
            padding: 7px 10px;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 7px;
            color: var(--text-muted);
            font-size: 13px; cursor: pointer;
            transition: all 0.2s;
        }

        .btn-card-fav:hover, .btn-card-fav.active { border-color: #f43f5e; color: #f43f5e; }

        /* Coming soon placeholder card */
        .coming-soon-card {
            background: var(--card-bg);
            border: 1px dashed var(--border);
            border-radius: 12px;
            width: 210px;
            height: 220px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
            opacity: 0.4;
        }

        .coming-soon-card .cs-icon { font-size: 36px; }
        .coming-soon-card p { font-size: 12px; color: var(--text-muted); text-align: center; padding: 0 16px; }

        /* No games in category message */
        .empty-category {
            padding: 30px;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
            background: var(--card-bg);
            border: 1px dashed var(--border);
            border-radius: 12px;
        }

        /* ── Footer ───────────────────────────────────────────── */
        .footer {
            background: var(--card-bg);
            border-top: 1px solid var(--border);
            padding: 50px 40px 30px;
        }

        .footer-top {
            display: flex; justify-content: space-between;
            flex-wrap: wrap; gap: 40px;
            margin-bottom: 40px;
            max-width: 1400px; margin-left: auto; margin-right: auto;
        }

        .footer-brand h2 { font-size: 22px; font-weight: 800; color: var(--primary); margin-bottom: 10px; }
        .footer-brand p { font-size: 13px; color: var(--text-muted); max-width: 220px; line-height: 1.6; }
        .footer-links h4 { font-size: 14px; font-weight: 700; margin-bottom: 14px; }
        .footer-links ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
        .footer-links ul a { color: var(--text-muted); text-decoration: none; font-size: 13px; transition: color 0.2s; }
        .footer-links ul a:hover { color: var(--primary); }

        .footer-bottom {
            border-top: 1px solid var(--border);
            padding-top: 24px;
            display: flex; justify-content: space-between;
            align-items: center; flex-wrap: wrap; gap: 12px;
            max-width: 1400px; margin: 0 auto;
        }

        .footer-bottom p { font-size: 13px; color: var(--text-muted); }
        .footer-bottom-links { display: flex; gap: 20px; }
        .footer-bottom-links a { font-size: 13px; color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
        .footer-bottom-links a:hover { color: var(--primary); }

        /* ── Toast Notification ───────────────────────────────── */
        .toast-notification {
            position: fixed;
            top: 80px;
            right: -400px;
            background: rgba(16, 185, 129, 0.9);
            color: #fff;
            padding: 16px 24px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(16, 185, 129, 0.4);
            font-weight: 700;
            font-size: 15px;
            z-index: 9999;
            transition: right 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            align-items: center;
            gap: 12px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .toast-notification.show {
            right: 40px;
        }

        .toast-icon {
            font-size: 20px;
        }

    </style>
</head>
<body>

    @if (TempData["Success"] != null)
    {
        <div class="toast-notification" id="successToast">
            <span class="toast-icon">✅</span>
            <span>@TempData["Success"]</span>
        </div>
        <script>
            setTimeout(() => {
