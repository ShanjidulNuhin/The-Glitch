@{
    ViewData["Title"] = "Glitch - Home";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Glitch — Your Game Store</title>
    <style>

        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --bg: #0f0f1a;
            --card-bg: #1a1a2e;
            --border: #2a2a4a;
            --text: #ffffff;
            --text-muted: #888;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', sans-serif;
            overflow-x: hidden;
        }

        /* ── Navbar ───────────────────────────────────────────── */
        .navbar {
            position: fixed;
            top: 0; left: 0;
            width: 100%;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 40px;
            background: rgba(15,15,26,0.92);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            gap: 16px;
        }

        /* Logo */
        .navbar-logo {
            font-size: 20px;
            font-weight: 800;
            color: var(--primary);
            text-decoration: none;
            letter-spacing: 1px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .navbar-logo span { color: #fff; }

        /* Search bar - middle */
        .navbar-search {
            flex: 1;
            max-width: 460px;
            position: relative;
        }

        .navbar-search input {
            width: 100%;
            padding: 9px 16px 9px 40px;
            background: rgba(42,42,74,0.6);
            border: 1px solid var(--border);
            border-radius: 50px;
            color: #fff;
            font-size: 14px;
            outline: none;
            transition: border 0.2s, background 0.2s;
        }

        .navbar-search input::placeholder { color: var(--text-muted); }

        .navbar-search input:focus {
            border-color: var(--primary);
            background: rgba(42,42,74,0.9);
        }

        /* Search icon inside input */
        .navbar-search .search-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 15px;
            pointer-events: none;
        }

        /* Search results dropdown */
        .search-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            width: 100%;
            background: #1a1a2e;
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            z-index: 9999;
            display: none;
            overflow: hidden;
            max-height: 380px;
            overflow-y: auto;
        }

        .search-dropdown.open { display: block; }

        .search-result-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            cursor: pointer;
            transition: background 0.15s;
            border-bottom: 1px solid rgba(42,42,74,0.5);
        }

        .search-result-item:last-child { border-bottom: none; }
        .search-result-item:hover { background: rgba(99,102,241,0.1); }

        .search-result-icon {
            font-size: 26px;
            width: 40px;
            height: 40px;
            background: var(--bg);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .search-result-info { flex: 1; }

        .search-result-name {
            font-size: 14px;
            font-weight: 700;
            margin-bottom: 3px;
        }

        .search-result-meta {
            display: flex;
            gap: 8px;
            font-size: 12px;
            color: var(--text-muted);
        }

        .search-result-price {
            font-size: 14px;
            font-weight: 700;
            color: var(--primary);
            flex-shrink: 0;
        }

        .search-no-results {
            padding: 20px;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
        }

        /* Highlight matched text */
        .highlight {
            color: var(--primary);
            font-weight: 800;
        }

        /* Navbar right buttons */
        .navbar-actions {
            display: flex;
            gap: 10px;
            flex-shrink: 0;
        }

        .btn-outline {
            padding: 8px 18px;
            border: 1px solid var(--primary);
            color: var(--primary);
            background: transparent;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .btn-outline:hover { background: var(--primary); color: #fff; }

        .btn-filled {
            padding: 8px 18px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s;
            white-space: nowrap;
        }

        .btn-filled:hover { background: var(--primary-dark); }

        /* ── Hero Slider ──────────────────────────────────────── */
        .hero-slider {
            position: relative;
            width: 100%;
            height: 100vh;
            overflow: hidden;
        }

        .slide {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 80px;
            opacity: 0;
            transform: translateX(100%);
            transition: transform 0.7s cubic-bezier(0.77,0,0.175,1), opacity 0.7s ease;
            z-index: 1;
        }

        .slide.active { opacity: 1; transform: translateX(0%); z-index: 2; }

        .slide.exit { opacity: 0; transform: translateX(-100%); z-index: 1; }

        /* Faded background image overlay */
        .slide-bg {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            z-index: 0;
            /* Faded look */
            opacity: 0.18;
            filter: blur(2px) saturate(1.4);
        }

        /* Dark overlay on top of faded bg */
        .slide-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(
                to right,
                rgba(15,15,26,0.98) 0%,
                rgba(15,15,26,0.80) 50%,
                rgba(15,15,26,0.50) 100%
            );
            z-index: 1;
        }

        .slide-content {
            position: relative;
            z-index: 3;
            max-width: 520px;
        }

        .slide-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(99,102,241,0.15);
            border: 1px solid rgba(99,102,241,0.3);
            color: var(--primary);
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 20px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .slide-title {
            font-size: clamp(36px, 5vw, 64px);
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 16px;
            background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .slide-description {
            font-size: 15px;
            color: var(--text-muted);
            line-height: 1.7;
            margin-bottom: 28px;
        }

        .slide-meta {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 28px;
        }

        .slide-price {
            font-size: 28px;
            font-weight: 800;
            color: var(--primary);
        }

        .slide-rating {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 14px;
            color: #fbbf24;
        }

        .slide-genre {
            font-size: 12px;
            background: var(--border);
            color: var(--text-muted);
            padding: 4px 10px;
            border-radius: 50px;
        }

        .slide-buttons { display: flex; gap: 12px; }

        .btn-buy {
            padding: 12px 28px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
            box-shadow: 0 0 24px rgba(99,102,241,0.4);
        }

        .btn-buy:hover { background: var(--primary-dark); transform: translateY(-2px); }

        .btn-wishlist {
            padding: 12px 28px;
            background: transparent;
            color: #fff;
            border: 1px solid var(--border);
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-wishlist:hover { border-color: var(--primary); color: var(--primary); }

        /* Faded game cover on the right */
        .slide-image {
            position: relative;
            z-index: 3;
            flex-shrink: 0;
        }

        .game-cover-placeholder {
            width: 280px;
            height: 360px;
            background: linear-gradient(135deg, #1e1e3a, #2a2a4a);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 80px;
            /* Faded effect */
            opacity: 0.7;
            box-shadow: 0 0 60px rgba(99,102,241,0.2);
            border: 1px solid rgba(99,102,241,0.15);
            filter: blur(0.5px);
        }

        /* Slider controls */
        .slider-controls {
            position: absolute;
            bottom: 40px;
            left: 80px;
            z-index: 10;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .slider-dots { display: flex; gap: 8px; }

        .dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--border);
            cursor: pointer;
            transition: all 0.3s;
        }

        .dot.active { background: var(--primary); width: 24px; border-radius: 4px; }

        .slider-arrows { display: flex; gap: 8px; }

        .arrow-btn {
            width: 38px; height: 38px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: rgba(26,26,46,0.8);
            color: #fff;
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .arrow-btn:hover { border-color: var(--primary); background: var(--primary); }

        .slider-progress {
            position: absolute;
            bottom: 0; left: 0;
            height: 3px;
            background: var(--primary);
            z-index: 10;
            animation: progressBar 5s linear infinite;
        }

        @@keyframes progressBar { 0% { width: 0%; } 100% { width: 100%; } }

        /* ── Games Section ────────────────────────────────────── */
        .games-section {
            padding: 80px 40px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-header { margin-bottom: 30px; }
        .section-header h2 { font-size: 22px; font-weight: 800; }
        .section-header p { font-size: 13px; color: var(--text-muted); margin-top: 4px; }

        /* Category tabs */
        .category-tabs {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }

        .tab-btn {
            padding: 8px 18px;
            border-radius: 50px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .tab-btn:hover { border-color: var(--primary); color: var(--primary); }
        .tab-btn.active { background: var(--primary); border-color: var(--primary); color: #fff; }

        /* Category block */
        .category-block {
            margin-bottom: 60px;
            display: none;
        }

        .category-block.visible { display: block; }

        .category-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border);
        }

        .category-title {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
            font-weight: 800;
        }

        /* Scroll arrows for each category row */
        .row-arrows { display: flex; gap: 8px; }

        .row-arrow {
            width: 32px; height: 32px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: var(--card-bg);
            color: #fff;
            font-size: 14px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .row-arrow:hover { border-color: var(--primary); background: var(--primary); }

        /* Scrollable row wrapper */
        .games-row-wrapper {
            overflow: hidden;
            position: relative;
        }

        /* The actual scrollable row */
        .games-row {
            display: flex;
            gap: 18px;
            overflow-x: auto;
            scroll-behavior: smooth;
            padding-bottom: 12px;
            cursor: grab;
            user-select: none;
            /* Hide scrollbar */
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

        .games-row::-webkit-scrollbar { display: none; }
        .games-row.dragging { cursor: grabbing; }

        /* Game card */
        .game-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
            cursor: pointer;
            flex-shrink: 0;
            width: 210px;
        }

        .game-card:hover {
            transform: translateY(-6px);
            border-color: var(--primary);
            box-shadow: 0 12px 40px rgba(99,102,241,0.2);
        }

        /* Faded game image placeholder */
        .game-card-thumb-placeholder {
            width: 100%;
            height: 140px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 44px;
            position: relative;
            overflow: hidden;
        }

        /* Each game has a unique faded gradient background */
        .game-card-thumb-placeholder::before {
            content: '';
            position: absolute;
            inset: 0;
            opacity: 0.35;
        }

        /* Faded overlay on card image */
        .game-card-thumb-placeholder::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 40%, var(--card-bg) 100%);
        }

        .game-card-thumb-placeholder .emoji {
            position: relative;
            z-index: 2;
            filter: drop-shadow(0 4px 12px rgba(0,0,0,0.5));
            opacity: 0.85;
        }

        /* Color themes per category */
        .theme-action::before { background: linear-gradient(135deg, #f43f5e, #fb7185); }
        .theme-adventure::before { background: linear-gradient(135deg, #10b981, #34d399); }
        .theme-rpg::before { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }
        .theme-racing::before { background: linear-gradient(135deg, #f59e0b, #fbbf24); }
        .theme-horror::before { background: linear-gradient(135deg, #374151, #6b7280); }
        .theme-sports::before { background: linear-gradient(135deg, #3b82f6, #60a5fa); }
        .theme-strategy::before { background: linear-gradient(135deg, #0891b2, #22d3ee); }
        .theme-shooter::before { background: linear-gradient(135deg, #dc2626, #ef4444); }

        .game-card-body { padding: 12px; }

        .game-card-name {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 6px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .game-card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .game-card-price { font-size: 14px; font-weight: 800; color: var(--primary); }

        .game-card-genre {
            font-size: 11px;
            color: var(--text-muted);
            background: var(--bg);
            padding: 3px 8px;
            border-radius: 50px;
        }

        .game-card-actions { display: flex; gap: 6px; }

        .btn-card-buy {
            flex: 1;
            padding: 7px;
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 7px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            transition: background 0.2s;
        }

        .btn-card-buy:hover { background: var(--primary-dark); }

        .btn-card-fav {
            padding: 7px 10px;
            background: transparent;
            border: 1px solid var(--border);
            border-radius: 7px;
            color: var(--text-muted);
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-card-fav:hover { border-color: #f43f5e; color: #f43f5e; }

        /* Search results section */
        .search-results-section {
            display: none;
            padding: 80px 40px 40px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .search-results-section.visible { display: block; }

        .search-results-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-top: 20px;
        }

        /* ── Footer ───────────────────────────────────────────── */
        .footer {
            background: var(--card-bg);
            border-top: 1px solid var(--border);
            padding: 50px 40px 30px;
        }

        .footer-top {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 40px;
            margin-bottom: 40px;
            max-width: 1400px;
            margin-left: auto;
            margin-right: auto;
        }

        .footer-brand h2 { font-size: 22px; font-weight: 800; color: var(--primary); margin-bottom: 10px; }
        .footer-brand p { font-size: 13px; color: var(--text-muted); max-width: 220px; line-height: 1.6; }
        .footer-links h4 { font-size: 14px; font-weight: 700; margin-bottom: 14px; }
        .footer-links ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
        .footer-links ul a { color: var(--text-muted); text-decoration: none; font-size: 13px; transition: color 0.2s; }
        .footer-links ul a:hover { color: var(--primary); }

        .footer-bottom {
            border-top: 1px solid var(--border);
            padding-top: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .footer-bottom p { font-size: 13px; color: var(--text-muted); }
        .footer-bottom-links { display: flex; gap: 20px; }
        .footer-bottom-links a { font-size: 13px; color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
        .footer-bottom-links a:hover { color: var(--primary); }

    </style>
</head>
<body>

    <!-- ── Navbar ──────────────────────────────────────────────── -->
    <nav class="navbar">

        <a href="/" class="navbar-logo">🎮 Game<span>Vault</span></a>

        <!-- Search bar -->
        <div class="navbar-search">
            <span class="search-icon">🔍</span>
            <input type="text"
                   id="searchInput"
                   placeholder="Search by name, category or price..."
                   autocomplete="off"
                   oninput="handleSearch(this.value)"
                   onfocus="showDropdown()"
                   onblur="hideDropdown()" />
            <!-- Search dropdown -->
            <div class="search-dropdown" id="searchDropdown"></div>
        </div>

        <div class="navbar-actions">
            <a href="/Account/Login" class="btn-outline">Login</a>
            <a href="/Account/Register" class="btn-filled">Register</a>
        </div>

    </nav>

    <!-- ── Hero Slider ─────────────────────────────────────────── -->
    <div class="hero-slider" id="heroSlider">

        <!-- Slide 1 - Action -->
        <div class="slide active" data-index="0">
            <div class="slide-bg" style="background: radial-gradient(ellipse at center, #f43f5e33 0%, #0f0f1a 70%);"></div>
            <div class="slide-overlay"></div>
            <div class="slide-content">
                <div class="slide-badge">🔥 Featured Game</div>
                <h1 class="slide-title">Cyber Legends</h1>
                <p class="slide-description">Dive into a neon-lit dystopian future where you fight for survival in a city controlled by mega-corporations. Open world, stunning visuals, endless freedom.</p>
                <div class="slide-meta">
                    <div class="slide-price">$29.99</div>
                    <div class="slide-rating">★★★★★ <span style="color:var(--text-muted)">4.9</span></div>
                    <div class="slide-genre">Action</div>
                </div>
                <div class="slide-buttons">
                    <a href="/Account/Register" class="btn-buy">🛒 Buy Now</a>
                    <a href="#games" class="btn-wishlist">❤️ Wishlist</a>
                </div>
            </div>
            <div class="slide-image">
                <div class="game-cover-placeholder">🎮</div>
            </div>
        </div>

        <!-- Slide 2 - RPG -->
        <div class="slide" data-index="1">
            <div class="slide-bg" style="background: radial-gradient(ellipse at center, #8b5cf633 0%, #0f0f1a 70%);"></div>
            <div class="slide-overlay"></div>
            <div class="slide-content">
                <div class="slide-badge">⚔️ Top Rated</div>
                <h1 class="slide-title">Shadow Realm</h1>
                <p class="slide-description">A dark fantasy RPG where your choices shape the world. Battle ancient demons, forge powerful alliances, and uncover the truth behind the Shadow Realm.</p>
                <div class="slide-meta">
                    <div class="slide-price">$19.99</div>
                    <div class="slide-rating">★★★★☆ <span style="color:var(--text-muted)">4.7</span></div>
                    <div class="slide-genre">RPG</div>
                </div>
                <div class="slide-buttons">
                    <a href="/Account/Register" class="btn-buy">🛒 Buy Now</a>
                    <a href="#games" class="btn-wishlist">❤️ Wishlist</a>
                </div>
            </div>
            <div class="slide-image">
                <div class="game-cover-placeholder">⚔️</div>
            </div>
        </div>

        <!-- Slide 3 - Adventure -->
        <div class="slide" data-index="2">
            <div class="slide-bg" style="background: radial-gradient(ellipse at center, #10b98133 0%, #0f0f1a 70%);"></div>
            <div class="slide-overlay"></div>
            <div class="slide-content">
                <div class="slide-badge">🚀 New Release</div>
                <h1 class="slide-title">Space Odyssey</h1>
                <p class="slide-description">Explore the infinite cosmos in this breathtaking space adventure. Build ships, colonize planets, and fight alien civilizations across the galaxy.</p>
                <div class="slide-meta">
                    <div class="slide-price">$39.99</div>
                    <div class="slide-rating">★★★★★ <span style="color:var(--text-muted)">4.8</span></div>
                    <div class="slide-genre">Adventure</div>
                </div>
                <div class="slide-buttons">
                    <a href="/Account/Register" class="btn-buy">🛒 Buy Now</a>
                    <a href="#games" class="btn-wishlist">❤️ Wishlist</a>
                </div>
