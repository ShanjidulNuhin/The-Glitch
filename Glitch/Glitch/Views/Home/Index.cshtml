    <!-- ── JavaScript ──────────────────────────────────────────── -->
    <script>

        // ═══════════════════════════════════════════════════
        // GAME DATA from database (passed from Razor)
        // ═══════════════════════════════════════════════════
        const allGames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Select(g => new {
                id       = g.Id,
                name     = g.Title,
                category = g.Genre,
                price    = g.Price,
                image    = g.ImageFileName
            })
        ));

        // ═══════════════════════════════════════════════════
        // FILTER STATE
        // ═══════════════════════════════════════════════════
        let currentSort = '';     // No sort selected by default

        // Select a sort option (only one at a time)
        function selectSort(sort) {
            currentSort = currentSort === sort ? '' : sort;
            // Remove selected from all sort chips
            ['newest','az','priceasc','pricedesc'].forEach(s => {
                document.getElementById('sort-' + s).classList.toggle('selected', currentSort === s);
            });
            // Auto apply sort
            applySortToAllRows();
        }

        // Apply filter — re-render game cards in page
        function applyFilter() {
            toggleFilter(); // close panel
            const query = document.getElementById('searchInput').value;
            filterGrid(query);
        }

        function filterGrid(query = '') {
            const q = query.toLowerCase();
            const grid = document.getElementById('gamesGrid');
            if (!grid) return;
            
            const cards = grid.querySelectorAll('.game-card');
            cards.forEach(card => {
                const name = card.getAttribute('data-name').toLowerCase();
                const category = card.getAttribute('data-category').toLowerCase();
                const price = card.getAttribute('data-price');
                
                const nameMatch = name.includes(q);
                const categoryMatch = category.includes(q);
                const priceMatch = price.includes(q);
                
                if (q === '' || nameMatch || categoryMatch || priceMatch) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
            applySortToAllRows();
        }

        // Sort all visible game rows
        function applySortToAllRows() {
            const grid = document.getElementById('gamesGrid');
            if (!grid) return;
            
            const cards = Array.from(grid.querySelectorAll('.game-card'));
            if (currentSort) {
                cards.sort((a, b) => {
                    const nameA  = a.querySelector('.game-card-name').textContent.trim();
                    const nameB  = b.querySelector('.game-card-name').textContent.trim();
                    const priceA = parseFloat(a.querySelector('.game-card-price').textContent.replace('$',''));
                    const priceB = parseFloat(b.querySelector('.game-card-price').textContent.replace('$',''));

                    if (currentSort === 'az')        return nameA.localeCompare(nameB);
                    if (currentSort === 'priceasc')  return priceA - priceB;
                    if (currentSort === 'pricedesc') return priceB - priceA;
                    return 0;
                });
            }
            
            // Re-append sorted cards
            cards.forEach(card => grid.appendChild(card));
        }

        // Clear all filters
        function clearFilter() {
            currentSort = '';
            ['newest','az','priceasc','pricedesc'].forEach(s => {
                document.getElementById('sort-' + s).classList.remove('selected');
            });
            document.getElementById('searchInput').value = '';
            filterGrid('');
            toggleFilter();
        }

        // Toggle filter panel open/close
        function toggleFilter() {
            const panel = document.getElementById('filterPanel');
            const btn   = document.getElementById('filterBtn');
            panel.classList.toggle('open');
            btn.classList.toggle('active');
        }

        // Close filter panel when clicking outside
        document.addEventListener('click', e => {
            const panel = document.getElementById('filterPanel');
            const btn   = document.getElementById('filterBtn');
            if (!panel.contains(e.target) && !btn.contains(e.target)) {
                panel.classList.remove('open');
                btn.classList.remove('active');
            }
        });

        // ═══════════════════════════════════════════════════
        // SEARCH LOGIC
        // ═══════════════════════════════════════════════════
        let searchTimeout;

        function handleSearch(query) {
            clearTimeout(searchTimeout);
            
            // Auto filter grid
            filterGrid(query);

            searchTimeout = setTimeout(() => {
                const dropdown = document.getElementById('searchDropdown');
                const q = query.trim().toLowerCase();

                if (q === '') { dropdown.classList.remove('open'); return; }

                const results = allGames.filter(game => {
                    const nameMatch     = game.name.toLowerCase().includes(q);
                    const categoryMatch = game.category.toLowerCase().includes(q);
                    const priceMatch    = game.price.toString().includes(q);
                    return nameMatch || categoryMatch || priceMatch;
                });

                if (results.length === 0) {
                    dropdown.innerHTML = `<div class="search-no-results">😕 No games found for "${query}"</div>`;
                } else {
                    dropdown.innerHTML = results.slice(0, 8).map(game => `
                        <div class="search-result-item" onmousedown="selectGame('${game.name}')">
                            <div class="search-result-icon">
                                ${game.image
                                    ? `<img src="/uploads/games/${game.image}" alt="${game.name}" />`
                                    : '🎮'}
                            </div>
                            <div class="search-result-info">
                                <div class="search-result-name">${highlightText(game.name, q)}</div>
                                <div class="search-result-genre">${highlightText(game.category, q)}</div>
                            </div>
                            <div class="search-result-price">$${game.price.toFixed(2)}</div>
                        </div>
                    `).join('');
                }

                dropdown.classList.add('open');
            }, 200);
        }

        function highlightText(text, query) {
            const regex = new RegExp(`(${query})`, 'gi');
            return text.replace(regex, '<span class="highlight">$1</span>');
        }

        function selectGame(name) {
            document.getElementById('searchInput').value = name;
            document.getElementById('searchDropdown').classList.remove('open');
            document.getElementById('games').scrollIntoView({ behavior: 'smooth' });
        }

        function showDropdown() {
            if (document.getElementById('searchInput').value.trim() !== '') {
                document.getElementById('searchDropdown').classList.add('open');
            }
        }

        function hideDropdown() {
            setTimeout(() => document.getElementById('searchDropdown').classList.remove('open'), 150);
        }

        // ═══════════════════════════════════════════════════
        // CATEGORY FILTER
        // ═══════════════════════════════════════════════════
        function filterCategory(category, btn) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');

            const grid = document.getElementById('gamesGrid');
            if (grid) {
                const cards = grid.querySelectorAll('.game-card');
                cards.forEach(card => {
                    if (category === 'all' || card.getAttribute('data-category').toLowerCase() === category.toLowerCase()) {
                        card.style.display = 'block';
                    } else {
                        card.style.display = 'none';
                    }
                });
            }

            document.getElementById('games').scrollIntoView({ behavior: 'smooth' });
        }

        // ═══════════════════════════════════════════════════
        // ROW SCROLL
        // ═══════════════════════════════════════════════════
        function scrollRow(rowId, amount) {
            document.getElementById(rowId).scrollBy({ left: amount, behavior: 'smooth' });
        }

        // ═══════════════════════════════════════════════════
        // HERO SLIDER
        // ═══════════════════════════════════════════════════
        const slides   = document.querySelectorAll('.slide');
        const dotsWrap = document.getElementById('sliderDots');
        const progress = document.getElementById('sliderProgress');
        let current    = 0;
        let timer;
        const duration = 5000;

        // Build dots dynamically based on slide count
        if (slides.length > 0 && dotsWrap) {
            slides.forEach((_, i) => {
                const dot = document.createElement('div');
                dot.className = 'dot' + (i === 0 ? ' active' : '');
                dot.onclick = () => { goToSlide(i); resetTimer(); };
                dotsWrap.appendChild(dot);
            });
        }

        function getDots() { return document.querySelectorAll('.dot'); }

        function goToSlide(index) {
            if (slides.length === 0) return;
            slides[current].classList.remove('active');
            slides[current].classList.add('exit');
            const exiting = slides[current];
            setTimeout(() => exiting.classList.remove('exit'), 700);
            getDots()[current]?.classList.remove('active');
            current = index;
            slides[current].classList.add('active');
            getDots()[current]?.classList.add('active');
            if (progress) {
                progress.style.animation = 'none';
                progress.offsetHeight;
                progress.style.animation = `progressBar ${duration/1000}s linear`;
            }
        }

        function nextSlide() { goToSlide((current + 1) % slides.length); }
        function prevSlide() { goToSlide((current - 1 + slides.length) % slides.length); }
        function resetTimer() { clearInterval(timer); timer = setInterval(nextSlide, duration); }

        if (slides.length > 0) {
            timer = setInterval(nextSlide, duration);
        }

        async function toggleWishlist(gameId, btn) {
            try {
                const res = await fetch('/Customer/ToggleWishlist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `gameId=${gameId}`
                });
                const data = await res.json();
                if (data.success) {
                    if (data.added) {
                        btn.classList.add('active');
                    } else {
                        btn.classList.remove('active');
                    }
                } else {
                    if (data.message === "Not logged in") {
                        window.location.href = '/Account/Login';
                    } else {
                        alert(data.message);
                    }
                }
            } catch (err) {
                console.error(err);
            }
        }

    </script>

</body>
</html>